{
    "openapi": "3.0.0",
    "info": {
        "title": "CVtify API",
        "description": "API for CVtify - Create professional CVs and Cover Letters",
        "contact": {
            "name": "CVtify Support",
            "email": "support@cvtify.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api",
            "description": "Local Development Server"
        },
        {
            "url": "https://your-ngrok-url.ngrok-free.app/api",
            "description": "ngrok Public Server"
        }
    ],
    "paths": {
        "/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Register a new user",
                "operationId": "5d4fa5d5607ed675ba93907e1fc94534",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "all"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Registration successful"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Login user",
                "operationId": "67d6d0fdd54fba132e1b6f55ca254183",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "remember": {
                                        "type": "boolean",
                                        "example": false
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "422": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/user": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Get authenticated user",
                "operationId": "2baab1eeb5fd49516237a38da22e7a07",
                "responses": {
                    "200": {
                        "description": "User data retrieved successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Logout user",
                "operationId": "28d48c13fca984400ac8de99f54ee13a",
                "responses": {
                    "200": {
                        "description": "Logged out successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/forgot-password": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Send password reset link",
                "operationId": "f46fe87b31c0dadd30642d353886e6f1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Reset link sent"
                    },
                    "422": {
                        "description": "Email not found"
                    }
                }
            }
        },
        "/reset-password": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Reset password",
                "operationId": "f93180f97c46f79e028b188d8763b2e1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "token",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "token": {
                                        "type": "string",
                                        "example": "abc123..."
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "newpassword123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "newpassword123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Password reset successful"
                    },
                    "422": {
                        "description": "Invalid token or email"
                    }
                }
            }
        },
        "/social-login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Social login",
                "description": "Handle social login (Google, LinkedIn)",
                "operationId": "403e8c8015bc8df3820b4f584003f175",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "provider",
                                    "provider_id",
                                    "name",
                                    "email",
                                    "avatar"
                                ],
                                "properties": {
                                    "provider": {
                                        "type": "string",
                                        "example": "google"
                                    },
                                    "provider_id": {
                                        "type": "string",
                                        "example": "1234567890"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@example.com"
                                    },
                                    "avatar": {
                                        "type": "string",
                                        "example": "https://example.com/avatar.jpg"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/templates": {
            "get": {
                "tags": [
                    "Templates"
                ],
                "summary": "Get all templates",
                "operationId": "e7bff3994948a3b495a185984da5e485",
                "parameters": [
                    {
                        "name": "filter",
                        "in": "query",
                        "description": "Filter templates",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "all",
                                "free",
                                "premium",
                                "popular"
                            ],
                            "example": "all"
                        }
                    },
                    {
                        "name": "category",
                        "in": "query",
                        "description": "Template category",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "creative",
                                "professional",
                                "simple"
                            ],
                            "example": "creative"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Templates retrieved successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                }
            }
        },
        "/api/templates/{template}": {
            "get": {
                "tags": [
                    "Templates"
                ],
                "summary": "Get a single template",
                "operationId": "ed6dce44f72216db9c0ab0a8daa9e37d",
                "parameters": [
                    {
                        "name": "template",
                        "in": "path",
                        "description": "Template ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Template retrieved successfully"
                    },
                    "404": {
                        "description": "Template not found"
                    }
                }
            }
        },
        "/api/templates/{template}/wishlist": {
            "post": {
                "tags": [
                    "Templates"
                ],
                "summary": "Toggle template wishlist",
                "operationId": "9e19eb1670df54c7ee0922de6f1acae4",
                "parameters": [
                    {
                        "name": "template",
                        "in": "path",
                        "description": "Template ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Wishlist updated"
                    },
                    "401": {
                        "description": "Authentication required"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/user/wishlist": {
            "get": {
                "tags": [
                    "Templates"
                ],
                "summary": "Get user's wishlisted templates",
                "operationId": "98a7dbc0b6d2bd681a2025fb127c91be",
                "responses": {
                    "200": {
                        "description": "Wishlist retrieved successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "apiKey",
                "description": "Enter your token (e.g., Token your-token-here)",
                "name": "Authorization",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Auth endpoints"
        },
        {
            "name": "User",
            "description": "User endpoints"
        },
        {
            "name": "Templates",
            "description": "Template endpoints"
        }
    ]
}